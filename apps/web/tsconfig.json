{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "paths": {
      "@lumadock/ui": ["../../packages/ui/src/index.ts"],
      "@lumadock/ui/*": ["../../packages/ui/src/*"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"]
    },
    "noEmit": true,
    "types": ["vite/client", "vitest/globals", "node"]
  },
  "include": ["src", "../packages/ui/src", "vite.config.ts", "playwright.config.ts", "e2e"]
}

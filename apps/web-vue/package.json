{
  "name": "@lumadock/web-vue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/e2e-runner.mjs",
    "build": "vue-tsc --noEmit && vite build",
    "build:analyze": "node scripts/build-analyze.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4174"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@lumadock/api-client": "*",
    "@lumadock/ui-vue": "*",
    "@tanstack/vue-query": "^5.66.0",
    "@tanstack/vue-virtual": "^3.13.24",
    "ant-design-vue": "^4.2.6",
    "echarts": "^5.6.0",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^2.3.0",
    "three": "^0.171.0",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^10.0.5",
    "vue-router": "^4.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.5.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.0",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.6.0",
    "jsdom": "^25.0.0",
    "msw": "^2.14.5",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.2.0"
  }

{
  "name": "lumadock-learning-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Independent React + TypeScript + FastAPI frontend learning product lab.",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm --workspace @lumadock/web run dev",
    "web:lint": "npm --workspace @lumadock/web run lint",
    "web:format": "npm --workspace @lumadock/web run format:check",
    "web:typecheck": "npm --workspace @lumadock/web run typecheck",
    "web:test": "npm --workspace @lumadock/web run test",
    "web:build": "npm --workspace @lumadock/web run build",
    "web:build:analyze": "npm --workspace @lumadock/web run build:analyze",
    "web:e2e": "npm --workspace @lumadock/web run test:e2e",
    "api:dev": "npm --workspace @lumadock/api run dev",
    "api:test": "npm --workspace @lumadock/api run test",
    "api-client:typecheck": "npm --workspace @lumadock/api-client run typecheck",
    "ui:storybook": "npm --workspace @lumadock/ui run storybook",
    "ui:build-storybook": "npm --workspace @lumadock/ui run build-storybook",
    "ui:typecheck": "npm --workspace @lumadock/ui run typecheck",
    "hooks:install": "node apps/web/node_modules/husky/bin.js",
    "precommit": "node apps/web/node_modules/lint-staged/bin/lint-staged.js --config lint-staged.config.mjs",
    "verify": "npm run web:lint && npm run web:format && npm run web:typecheck && npm run web:test && npm run web:build && npm run web:build:analyze && npm run ui:typecheck && npm run ui:build-storybook && npm run api-client:typecheck && npm run api:test"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
